# ── Polymarket (same wallet stack as bear bot) ──────────────────────
# Run setup.py from a local/residential machine to populate the derived
# API credentials automatically.
POLY_PRIVATE_KEY=0x...
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_FUNDER_ADDRESS=0x...
POLY_SIG_TYPE=3

# ── Live deposit-wallet SDK (polymarket-client) ─────────────────────
RELAYER_API_KEY=
RELAYER_ADDRESS=0x...
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=
BUILDER_CODE=

# ── Anthropic (LLM pair + ambiguity detection) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Arb bot specific (read by core/config.py env overrides) ─────────
ARB_MIN_SPREAD_CENTS=2.0
ARB_MIN_OPP_PER_DAY=5
ARB_MIN_DURATION_SEC=15
